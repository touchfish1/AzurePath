{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AzurePath",
  "version": "0.1.0",
  "identifier": "com.azurepath.app",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "AzurePath",
        "width": 1180,
        "height": 760,
        "minWidth": 900,
        "minHeight": 620,
        "decorations": false,
        "visible": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; connect-src 'self' http://127.0.0.1:1420; font-src 'self' data:; object-src 'none'; frame-ancestors 'none'; form-action 'self'; base-uri 'self'"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEREOTQ2QzNGN0FENDdEQzQKUldURWZkUjZQMnlVM2NIRWdjYnBVSHlsc1BHdTI0ZlorSmcyWlFFdlJxODVnRjlQN1hIVThlYnAK",
      "endpoints": ["https://github.com/chengccn/AzurePath/releases/latest/download/updates.json"],
      "windows": { "installMode": "passive" }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/icon.ico"]
  }
}
